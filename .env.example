# Reddit script-app credentials (free, register at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=cursed-sentiment by /u/yourusername

# Groq API key (free, no card, register at https://console.groq.com)
GROQ_API_KEY=

# Salt for author-name hashing — change before first run, never commit a real one
CURSED_AUTHOR_SALT=change-me

# Optional: override the data directory (defaults to ./data)
# CURSED_DATA_DIR=/path/to/data

# Optional: override the LLM endpoint (defaults to Groq)
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.1-8b-instant